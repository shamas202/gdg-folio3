# ====================================
# INTERIOR VISUAL SEARCH CONFIGURATION
# Copy to .env and fill in your values
# ====================================

APP_NAME="Interior Visual Search"
APP_ENV="dev"
LOG_LEVEL="INFO"

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=interior-products-gemini
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIM=3072
# Override for testing
PINECONE_INDEX_OVERRIDE=
PINECONE_API_KEY_OVERRIDE=

# Gemini Embedding
GOOGLE_API_KEY=your_google_api_key
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2-preview

# YOLO11n detection confidence (0.0 – 1.0)
DETECTION_CONFIDENCE_THRESHOLD=0.15

# Image validation
IMAGE_MIN_DIMENSION=300
IMAGE_MAX_DIMENSION=4096
IMAGE_MAX_SIZE_MB=10

# Image storage
CATALOG_IMAGES_DIR=images/catalog
SEARCH_IMAGES_DIR=images/search

# Search
SEARCH_CANDIDATE_MULTIPLIER=15
MAX_CANDIDATE_K=500
